# ============================================================
# BITRIX24 INCOMING WEBHOOK
# ============================================================
#
# Bitrix24'da qanday yaratish:
#
#   1. https://avtocitypro.bitrix24.kz ga kiring (admin sifatida)
#   2. Приложения → Разработчикам → Другое → Входящий вебхук
#   3. Nom: "Web sayt lead'lari"
#   4. Huquqlar (Права доступа) bo'limida BELGILANG:
#      - CRM (crm)
#   5. Сохранить tugmasini bosing
#   6. Yaratilgan URL'ni shu yerga ko'chirib qo'ying:
#
# URL formati:
#   https://avtocitypro.bitrix24.kz/rest/{USER_ID}/{WEBHOOK_TOKEN}/
#
# DIQQAT: Bu URL maxfiy! Hech qachon GitHub'ga yoki public joyga qo'ymang.
# Faqat .env.local va Vercel'ning Environment Variables ichida saqlang.
# ============================================================

BITRIX_WEBHOOK_URL=https://avtocitypro.bitrix24.kz/rest/1/xxxxxxxxxxxxxxxx/
